rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cache collection - browser reads coverage data from cache/coverage
    match /cache/{document=**} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write (Admin SDK bypasses rules)
    }

    // Technique mappings (individual technique docs)
    match /techniques/{techniqueId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
