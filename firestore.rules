rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Coverage data - read from frontend, write from functions only
    match /coverage/{document=**} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
    }

    // Technique mappings
    match /techniques/{techniqueId} {
      allow read: if true;
      allow write: if false;
    }

    // Cache metadata
    match /cache/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
