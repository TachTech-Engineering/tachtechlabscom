{
  "name": "tachtechlabs-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for CrowdStrike API proxy",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "typescript": "^5.4.0"
  },
  "private": true
}
